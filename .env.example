# ======================
# Core API configuration
# ======================
MODELS_CONFIG=/config/models.yaml
LOG_LEVEL=INFO
LOG_JSON=true
ENVIRONMENT=production

# Comma-separated list of allowed CORS origins.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ======================
# Persistence backends
# ======================
# vector_backend: memory | pgvector
# session_backend: memory | redis
VECTOR_BACKEND=pgvector
SESSION_BACKEND=redis
DATABASE_URL=postgresql+asyncpg://compare:compare@postgres:5432/compare
REDIS_URL=redis://redis:6379/0

# ======================
# Floating Prompts (optional): load managed system prompts.
# Unset = feature disabled. Host run: http://localhost:8000.
# From the api container: http://host.docker.internal:8000.
# ======================
# FLOATING_PROMPTS_URL=http://localhost:8000

# ======================
# Provider API keys
# ======================
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
GOOGLE_API_KEY=AIza-your-google-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
VOYAGE_API_KEY=pa-your-voyage-api-key-here
COHERE_API_KEY=your-cohere-api-key-here
CEREBRAS_API_KEY=csk-your-cerebras-api-key-here

# Ollama runs locally and needs no API key (ensure the service is reachable).
